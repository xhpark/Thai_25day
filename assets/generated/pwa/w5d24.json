  "keywordDisplayPolicy": {
    "default": "core_only",
    "toggleSupplemental": true,
    "emptyCoreFallback": "show_first_three_keywords"
  },
  "learnerProfile": {
    "ageRange": "primarily older Korean adults; source plan average age about 58",
    "smartphoneLiteracy": "low_to_moderate",
    "uxDefaults": {
      "minimumTapTargetPx": 48,
      "audioPlayback": "manual_user_triggered",
      "localStorageFailure": "silent_degrade_with_reset_option",
      "defaultTextScale": "large"
    }
  },
  "statePolicy": {
    "storage": "localStorage",
    "schemaVersion": 1,
    "namespace": "thai25",
    "keys": {
      "schemaVersion": {
        "key": "thai25.schemaVersion",
        "type": "number",
        "default": 1
      },
      "currentDay": {
        "key": "thai25.currentDay",
        "type": "number",
        "default": 1
      },
      "completedLessonIds": {
        "key": "thai25.completedLessonIds",
        "type": "string[]",
        "default": []
      },
      "lastOpenedLessonId": {
        "key": "thai25.lastOpenedLessonId",
        "type": "string|null",
        "default": null
      },
      "speakerPreference": {
        "key": "thai25.speakerPreference",
        "type": "\"male\"|\"female\"",
        "default": "female"
      },
      "audioSpeedPreference": {
        "key": "thai25.audioSpeedPreference",
        "type": "\"normal\"|\"slow\"|\"repeat3\"",
        "default": "normal"
      },
      "showSupplementalKeywords": {
        "key": "thai25.showSupplementalKeywords",
        "type": "boolean",
        "default": false
      }
    },
    "resetSupported": true,
    "fallback": "If localStorage is unavailable, keep the lesson usable with stateless navigation and show no blocking error."
  },
  "imageMissingFallback": {
    "behavior": "show_placeholder_panel",
    "placeholderTextSource": "primaryImage.altTextKo",
    "visualStyle": "light neutral panel with scene label; preserve image aspect ratio so layout does not shift when real image is added",
    "allowRenderWithoutImageFile": true
  },
  "controls": {
    "sentenceAudioModes": [
      "normal",
      "slow",
      "repeat3"
    ],
    "wordAudioModes": [
      "normal",
      "slow"
    ],
    "speakerModes": [
      "male",
      "female"
    ],
    "audioSpeedControlPlacement": {
      "placement": "inline_sentence_audio_toolbar",
      "visibleOptions": [
        "normal",
        "slow",
        "repeat3"
      ],
      "default": "normal",
      "reason": "Older learners should not have to find a settings screen to slow down audio."
    }
  },
  "completion": {
    "checkAction": "lesson_complete",
    "shareAction": "open_kakao_share_card",
    "nextAction": "next_day_or_review"
  }
}
