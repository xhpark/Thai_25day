  "week": 2,
  "day": 7,
  "theme": "새 친구 만나기",
  "title": "이름 묻기",
  "hook": "이름을 묻는 한 문장으로 대화가 열린다.",
  "missionGoal": "이름을 묻고 기억하는 대화를 시작한다.",
  "ministryGuide": "상대 이름을 불러 주는 것은 관계를 빠르게 가깝게 만드는 좋은 출발점이다.",
  "speakingMission": "이름이 무엇인가요를 5회 말하고, 미소와 함께 2회 더 연습한다.",
  "primaryImage": {
    "sceneId": "name_intro_conversation",
    "altTextKo": "교회 친교 자리에서 이름을 묻고 자기 이름을 소개하는 장면",
    "sourcePlan": [
      {
        "type": "local_preferred",
        "assetPath": "assets/images/scenes/name_intro_conversation.jpg",
        "status": "ready"
      },
      {
        "type": "stock_preferred",
        "queries": [
          "church fellowship two people introducing themselves",
          "Asian church conversation after worship",
          "friendly introduction conversation church"
        ],
        "status": "search_required"
      },
      {
        "type": "ai_fallback",
        "prompt": {
          "scene": "new friends meeting after worship",
          "peopleAndAction": "two adults introducing themselves, relaxed smile, respectful posture",
          "setting": "church fellowship hall",
          "mood": "friendly, welcoming, personal",
          "cameraFraming": "medium shot",
          "lighting": "bright indoor natural light",
          "avoidList": [
            "formal business handshake",
            "stage presentation feel"
          ]
        },
        "status": "generate_if_needed"
      }
    ]
  },
