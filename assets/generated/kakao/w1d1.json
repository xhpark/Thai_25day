  "week": 1,
  "day": 1,
  "theme": "태국 교회 첫 방문",
  "title": "첫 인사 시작하기",
  "hook": "와이 인사와 함께 첫 문장을 입에 붙인다.",
  "missionGoal": "첫 만남에서 따뜻한 분위기를 여는 태국어 인사를 익힌다.",
  "ministryGuide": "처음 만난 사람에게는 문장을 길게 설명하기보다 와이 인사와 미소를 먼저 보여 주고, 상대가 웃거나 고개를 끄덕이면 같은 인사를 한 번 더 천천히 말한다.",
  "speakingMission": "화면에서 선택한 발화로 \"사-왓-디 카\"(여성) 또는 \"사-왓-디 크랍\"(남성)을 5회 또렷하게 말해요. 그다음 두 손을 모아 와이 인사를 하면서 같은 말을 2회 더 말해요.",
  "primaryImage": {
    "sceneId": "greeting_church_gate",
    "altTextKo": "교회 입구에서 태국 성도에게 와이 인사로 반갑게 인사하는 장면",
    "sourcePlan": [
      {
        "type": "local_preferred",
        "assetPath": "assets/images/scenes/greeting_church_gate.jpg",
        "status": "ready"
      },
      {
        "type": "stock_preferred",
        "queries": [
          "Thai church entrance greeting people smiling wai",
          "Asian church greeting outside entrance",
          "warm greeting at church gate Thailand"
        ],
        "status": "search_required"
      },
      {
        "type": "ai_fallback",
        "prompt": {
          "scene": "Korean mission team greeting Thai church member",
          "peopleAndAction": "two or three adults smiling, gentle wai greeting, warm eye contact",
          "setting": "church entrance in Thailand, daytime",
          "mood": "welcoming, respectful, calm",
          "cameraFraming": "medium wide documentary photo",
          "lighting": "soft natural daylight",
          "avoidList": [
            "tourist pose",
            "crowded street chaos",
            "dramatic religious painting style"
          ]
        },
        "status": "generate_if_needed"
      }
    ]
  },
