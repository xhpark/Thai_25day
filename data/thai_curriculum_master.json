{
  "metadata": {
    "title": "Thai 25-day mission learning curriculum master",
    "version": "1.0.0",
    "purpose": "Single source of truth for weekday learning materials, Saturday offline teaching materials, and Sunday personal review materials.",
    "language": {
      "source": "ko",
      "target": "th"
    },
    "sourceFiles": {
      "phrases": "data/thai_master_phrases.json",
      "assetsIndex": "data/thai_learning_assets_index.json"
    }
  },
  "contentPolicy": {
    "primaryGoal": "mission_learning",
    "ministryGuideField": "ministryGuide",
    "ministryGuidePolicy": "Use ministryGuide to support natural, relationship-centered witness. Avoid discouraging or blocking mission activity. Prefer guidance that helps the learner choose warm timing, relational sensitivity, encouragement, prayer, blessing, and invitation.",
    "voicePolicy": "Provide both male and female Thai speech for every sentence and major keyword.",
    "outputPolicy": "Generate Kakao cards, PWA lesson pages, weekly PPT, teacher notes, roleplay cards, and printable review sheets from this master file.",
    "pwaStatePolicy": {
      "storage": "localStorage",
      "reason": "Short-term PWA with no backend; older learners need return-to-current-day and completion memory.",
      "tracks": [
        "currentDay",
        "completedLessonIds",
        "lastOpenedLessonId",
        "speakerPreference",
        "audioSpeedPreference"
      ],
      "resetSupported": true
    }
  },
  "generatorTargets": {
    "kakaoCard": {
      "requiredFields": [
        "title",
        "hook",
        "newPhraseVariantIds",
        "reviewVariantIds",
        "keyWordIds",
        "speakingMission",
        "assets"
      ]
    },
    "pwaLesson": {
      "requiredFields": [
        "assets",
        "completion",
        "keyWordIds",
        "ministryGuide",
        "missionGoal",
        "newPhraseVariantIds",
        "pwaStatePolicy",
        "reviewVariantIds",
        "speakingMission",
        "story",
        "title"
      ]
    },
    "saturdayLessonPack": {
      "requiredFields": [
        "title",
        "roleplayScene",
        "roleplayFocusVariantIds",
        "teacherFlow",
        "ministryGuide",
        "assets"
      ]
    },
    "sundayReview": {
      "requiredFields": [
        "title",
        "reviewVariantIds",
        "keyWordIds",
        "personalMission",
        "ministryGuide",
        "assets"
      ]
    }
  },
